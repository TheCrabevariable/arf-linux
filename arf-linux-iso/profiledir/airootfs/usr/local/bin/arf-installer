#!/usr/bin/env bash
set -euo pipefail

# ── arf-linux installer (runs from live ISO) ──────────────────
# Uses gum for all interactive prompts (handles serial console properly)

info()  { gum style ":: $*" --foreground "#00ffff"; }
ok()    { gum style "==> $*" --foreground "#00ff00" --bold; }
err()   { gum style "==> $*" --foreground "#ff0000" --bold >&2; exit 1; }

gum style --border double --padding "1 2" --foreground "#00ffff" --bold "arf-linux Installer"

# ── Detect arf-linux source ───────────────────────────────────
ARF_SRC="/opt/arf-linux"
if [ ! -d "$ARF_SRC" ]; then
  err "arf-linux source not found at /opt/arf-linux. Rebuild the ISO with the source bundled."
fi

# ── Disk selection ────────────────────────────────────────────
DISK=$(lsblk -dpno NAME,SIZE,MODEL | grep -v loop | gum choose --header "Select install disk" | awk '{print $1}')
[ -z "$DISK" ] && err "No disk selected"
[ ! -b "$DISK" ] && err "Not a block device: $DISK"

# ── WiFi setup ────────────────────────────────────────────────
if command -v nmcli &>/dev/null && nmcli radio wifi | grep -q enabled; then
  info "Scanning for WiFi networks..."
  nmcli dev wifi list --rescan yes 2>/dev/null | head -40 || true
  WIFI_SSID=$(gum input --placeholder "SSID or leave blank to skip" --prompt "WiFi SSID> ")
  if [ -n "$WIFI_SSID" ]; then
    WIFI_PASS=$(gum input --password --placeholder "Password" --prompt "WiFi password> ")
    info "Connecting to ${WIFI_SSID}..."
    nmcli dev wifi connect "$WIFI_SSID" password "$WIFI_PASS" 2>&1 || err "Failed to connect to WiFi"
    ok "Connected to ${WIFI_SSID}"
  fi
else
  info "No WiFi device detected — will use Ethernet (if available)"
fi

# ── User info ─────────────────────────────────────────────────
HOSTNAME=$(gum input --placeholder "myhostname" --prompt "Hostname> " --value "arf-pc")
[ -z "$HOSTNAME" ] && err "Hostname required"

USERNAME=$(gum input --placeholder "username" --prompt "Username> ")
[ -z "$USERNAME" ] && err "Username required"

PASSWORD=$(gum input --password --prompt "Password> ")
[ -z "$PASSWORD" ] && err "Password required"

TIMEZONE=$(timedatectl list-timezones 2>/dev/null | gum filter --placeholder "Type to search..." --header "Select timezone" --height 15)
if [ -z "$TIMEZONE" ]; then
  TIMEZONE=$(gum input --placeholder "America/New_York" --prompt "Timezone> ")
fi
[ -z "$TIMEZONE" ] && err "Timezone required"

# ── Mirrorlist optimization ────────────────────────────────────
info "Optimizing mirrorlist for your location..."
reflector --latest 20 --sort rate --save /etc/pacman.d/mirrorlist 2>&1 || info "Mirrorlist optimization skipped (no internet?)"
ok "Mirrorlist optimized"

FS_CHOICE=$(gum choose "btrfs" "ext4" --header "Filesystem")

# ── Confirmation ──────────────────────────────────────────────
gum confirm --affirmative "Yes, wipe it" --negative "Abort" "⚠️  THIS WILL WIPE ALL DATA ON $DISK" || err "Aborted by user"

# ── Detect SSD & partition prefix ─────────────────────────────
IS_SSD=false
DISK_NAME="$(basename "$DISK")"
if [ -f "/sys/block/$DISK_NAME/queue/rotational" ]; then
  [ "$(cat "/sys/block/$DISK_NAME/queue/rotational")" = "0" ] && IS_SSD=true
fi
case "$DISK_NAME" in
  nvme*|mmcblk*) PART_PREFIX="p" ;;
  *)             PART_PREFIX="" ;;
esac
PART1="${DISK}${PART_PREFIX}1"
PART2="${DISK}${PART_PREFIX}2"

# ── Partition, format, mount ──────────────────────────────────
info "Partitioning $DISK..."
parted -s "$DISK" mklabel gpt
parted -s "$DISK" mkpart primary fat32 1MiB 1025MiB
parted -s "$DISK" set 1 esp on
sleep 1
partprobe "$DISK" 2>/dev/null || true

if [ "$FS_CHOICE" = "btrfs" ]; then
  parted -s "$DISK" mkpart primary btrfs 1025MiB 100%
  sleep 1
  partprobe "$DISK" 2>/dev/null || true
  info "Formatting partitions..."
  mkfs.fat -F32 "$PART1"
  wipefs -a "$PART2" 2>/dev/null || true
  mkfs.btrfs -f "$PART2"
  mount "$PART2" /mnt
  if gum confirm "Create subvolumes (@, @home, @snapshots)?" --default=true; then
    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@snapshots
    umount /mnt
    mount -o subvol=@,compress=zstd "$PART2" /mnt
    mkdir -p /mnt/{home,.snapshots}
    mount -o subvol=@home,compress=zstd "$PART2" /mnt/home
    mount -o subvol=@snapshots,compress=zstd "$PART2" /mnt/.snapshots
    if gum confirm "Configure snapper snapshots?" --default=true; then
      SNAPPER_PKG=1
    else
      SNAPPER_PKG=''
    fi
  else
    SNAPPER_PKG=''
    umount /mnt
    mount -o compress=zstd "$PART2" /mnt
  fi
else
  SNAPPER_PKG=''
  parted -s "$DISK" mkpart primary ext4 1025MiB 100%
  sleep 1
  partprobe "$DISK" 2>/dev/null || true
  info "Formatting partitions..."
  mkfs.fat -F32 "$PART1"
  wipefs -a "$PART2" 2>/dev/null || true
  mkfs.ext4 -F "$PART2"
  mount "$PART2" /mnt
fi

mkdir -p /mnt/boot
mount "$PART1" /mnt/boot

ok "Partitions created and mounted"

# ── Kernel selection ──────────────────────────────────────────
KERNEL=$(gum choose --header "Choose kernel" "linux" "linux-zen")
[ -z "$KERNEL" ] && KERNEL="linux"

# ── Install base system ───────────────────────────────────────
info "Installing base system via pacstrap..."

PACSTRAP_PKGS=(
  base "$KERNEL" linux-firmware
  base-devel
  grub efibootmgr
  sudo networkmanager
  git btop
  reflector
  zsh
)
if [ -n "${SNAPPER_PKG:-}" ]; then
  PACSTRAP_PKGS+=(snapper)
fi

pacstrap -K /mnt "${PACSTRAP_PKGS[@]}"
ok "Base system installed"

# ── Configure installed system ────────────────────────────────
info "Configuring installed system..."

genfstab -U /mnt >> /mnt/etc/fstab

arch-chroot /mnt ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
arch-chroot /mnt hwclock --systohc

sed -i 's/^#en_US.UTF-8/en_US.UTF-8/' /mnt/etc/locale.gen
arch-chroot /mnt locale-gen
echo "LANG=en_US.UTF-8" > /mnt/etc/locale.conf

echo "$HOSTNAME" > /mnt/etc/hostname
cat > /mnt/etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS

echo "root:$PASSWORD" | arch-chroot /mnt chpasswd
arch-chroot /mnt useradd -m -G wheel,video,input -s /bin/zsh "$USERNAME"
echo "$USERNAME:$PASSWORD" | arch-chroot /mnt chpasswd
echo "%wheel ALL=(ALL:ALL) ALL" > /mnt/etc/sudoers.d/10-wheel

arch-chroot /mnt grub-install --target=x86_64-efi --efi-directory=/boot --bootloader-id=GRUB
arch-chroot /mnt grub-mkconfig -o /boot/grub/grub.cfg
arch-chroot /mnt mkinitcpio -P
arch-chroot /mnt systemctl enable NetworkManager

ok "Base system configured"

# ── Persist WiFi connection ───────────────────────────────────
if [ -n "${WIFI_SSID:-}" ]; then
  info "Copying WiFi connection to installed system..."
  WIFI_UUID="$(nmcli -t -f UUID,DEVICE,TYPE conn show --active 2>/dev/null | grep -F ':wifi' | cut -d: -f1 | head -1)" || true
  nmcli connection export "${WIFI_UUID:-$WIFI_SSID}" /tmp/arf-wifi.nmconnection 2>/dev/null || true
  if [ -f /tmp/arf-wifi.nmconnection ]; then
    cp /tmp/arf-wifi.nmconnection /mnt/etc/NetworkManager/system-connections/
    chown root:root /mnt/etc/NetworkManager/system-connections/*.nmconnection
    chmod 600 /mnt/etc/NetworkManager/system-connections/*.nmconnection
    ok "WiFi connection saved to installed system"
  fi
fi

# ── Copy arf-linux to installed system ────────────────────────
info "Copying arf-linux to installed system..."
mkdir -p /mnt/home/${USERNAME}/arf-linux
cp -r "$ARF_SRC"/* /mnt/home/${USERNAME}/arf-linux/
chown -R 1000:1000 /mnt/home/${USERNAME}/arf-linux 2>/dev/null || true

# ── Set up auto-stage2 on first boot ──────────────────────────
info "Setting up auto-stage2 on first boot..."
mkdir -p /mnt/etc/systemd/system

echo "USERNAME=${USERNAME}" > /mnt/etc/arf-linux.env

cat > /mnt/etc/systemd/system/arf-stage2.service <<SERVICE
[Unit]
Description=arf-linux stage2 (packages + dotfiles)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/etc/arf-linux.env
ExecStart=/home/${USERNAME}/arf-linux/install.sh --stage2
ExecStartPost=/usr/bin/systemctl disable arf-stage2.service
StandardOutput=journal+console

[Install]
WantedBy=multi-user.target
SERVICE

mkdir -p /mnt/etc/systemd/system/multi-user.target.wants
ln -sf /etc/systemd/system/arf-stage2.service /mnt/etc/systemd/system/multi-user.target.wants/arf-stage2.service

# ── Copy bundled SDDM theme to installed system ──────────────
if [ -d /usr/share/sddm/themes/sddm-flower-theme ]; then
  mkdir -p /mnt/usr/share/sddm/themes/sddm-flower-theme
  cp -r /usr/share/sddm/themes/sddm-flower-theme/* /mnt/usr/share/sddm/themes/sddm-flower-theme/
  ok "Bundled SDDM theme copied to installed system"
fi

# ── Configure snapper snapshots ───────────────────────────────
if [ -n "${SNAPPER_PKG:-}" ]; then
  info "Configuring snapper snapshots..."
  arch-chroot /mnt bash -c "
    snapper -c root create-config /
    snapper -c home create-config /home
    systemctl enable snapper-timeline.timer snapper-cleanup.timer
    systemctl enable snapper-boot.service
  " 2>&1 || true
  ok "Snapper configured for @ (/) and @home"
fi

# ── Enable fstrim if SSD ──────────────────────────────────────
if [ "$IS_SSD" = true ]; then
  info "Enabling fstrim.timer (SSD detected)"
  ln -sf /usr/lib/systemd/system/fstrim.timer /mnt/etc/systemd/system/timers.target.wants/fstrim.timer 2>/dev/null || true
fi

# ── Run stage2 in chroot ──────────────────────────────────────
info "Running stage2 in chroot..."
cp /etc/resolv.conf /mnt/etc/resolv.conf 2>/dev/null || true
if arch-chroot /mnt bash -c "
  export USERNAME=$USERNAME HOME=/home/$USERNAME
  bash /home/$USERNAME/arf-linux/install.sh --stage2
  # Disable the first-boot service since we ran successfully in chroot
  rm -f /etc/systemd/system/multi-user.target.wants/arf-stage2.service
  rm -f /etc/systemd/system/arf-stage2.service
  rm -f /etc/arf-linux.env
" 2>&1; then
  ok "Stage2 complete"
else
  gum style "Stage2 had some errors. The service will retry on first boot." --foreground yellow
fi

# ── Done ──────────────────────────────────────────────────────
ok "Installation complete! Rebooting in 5 seconds..."
sleep 5
reboot
