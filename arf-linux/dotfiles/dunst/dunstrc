[global]
font = Hack Nerd Font 10
markup = full
plain_text = no
frame_width = 2
frame_color = "#1e2030"
separator_color = frame
sort = yes
stack_duplicates = yes
show_indicator = no
idle_threshold = 120
ignore_transient = no
mouse_left = close_current
mouse_middle = do_action
mouse_right = close_all

[urgency_low]
background = "#1e2030"
foreground = "#c0caf5"
timeout = 5

[urgency_normal]
background = "#1e2030"
foreground = "#c0caf5"
timeout = 10

[urgency_critical]
background = "#1e2030"
foreground = "#f7768e"
timeout = 0
